VIOLOOP_HOST=127.0.0.1
VIOLOOP_PORT=8787
# Optional Vite proxy overrides only.
#
# Worker allowlists (VIOLOOP_ALLOWED_ORIGINS, VIOLOOP_ALLOWED_PROVIDER_HOSTS)
# are Wrangler vars, set in wrangler.toml / `wrangler secret`, not here.
# They default to empty, which is an OPEN policy (any origin, any non-private
# HTTPS provider host). That is fine for local dev but MUST be set to an
# explicit allowlist before a public deployment.
