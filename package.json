{
	"name": "violoop",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n worker,web -c cyan,green \"pnpm dev:worker\" \"pnpm dev:web\"",
		"dev:worker": "wrangler dev --local",
		"dev:web": "vite --host 0.0.0.0",
		"build": "tsc --noEmit && vite build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check .",
		"preview": "vite preview --host 127.0.0.1",
		"deploy": "pnpm build && pnpm exec wrangler deploy"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"hono": "^4.12.29",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@tailwindcss/vite": "^4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.10.2",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"concurrently": "^9.2.1",
		"fake-indexeddb": "^6.2.5",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3",
		"vite": "^7.2.7",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"engines": {
		"node": ">=22.19.0"
	}
}
